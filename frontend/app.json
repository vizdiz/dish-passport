{
  "expo": {
    "name": "Dish Passport",
    "slug": "dish-passport",
    "scheme": "dishport",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#FBF7F0",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dishport.app",
      "buildNumber": "1"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.dishport.app",
      "versionCode": 1
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Dish Passport uses your photos so you can attach a picture of a dish you logged."
        }
      ],
      "expo-font",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ]
  }
}
