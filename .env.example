# ============================================================================
# Dish Passport — copy to `.env` and fill in. Env vars are DP_-prefixed
# (pydantic-settings env_prefix="DP_"). Tests run on in-memory fakes and need NONE of these.
# ============================================================================

# asyncpg DSN — plain postgresql:// (NOT a SQLAlchemy +driver URL).
# Prod: Azure Database for PostgreSQL (flexible server) with the pgvector extension.
DP_DATABASE_URL=postgresql://dishport:dishport@localhost:5432/dishport

# Celery (batch scheduler) — local Redis; prod: Azure Cache for Redis.
DP_CELERY_BROKER_URL=redis://localhost:6379/0
DP_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# OpenAI — powers BOTH embeddings and the flavor/normalization call. Required to run the gate.
DP_OPENAI_API_KEY=
DP_EMBEDDING_MODEL=text-embedding-3-small
DP_FLAVOR_MODEL=gpt-4o-mini

# Azure Blob Storage (dish photos). Default targets the local Azurite emulator.
# Prod: set the real account connection string + a public base (container/CDN).
DP_AZURE_STORAGE_CONNECTION_STRING=
DP_AZURE_STORAGE_CONTAINER=dishport-photos
DP_AZURE_BLOB_PUBLIC_BASE=

# Tunables
DP_DEDUP_TAU=0.90
DP_LOG_LEVEL=INFO
