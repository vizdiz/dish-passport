# ============================================================================
# Dish Passport — Service 1 (Ingestion). Copy to `.env` and fill in.
# Env vars are DP_-prefixed (pydantic-settings env_prefix="DP_").
# Tests run on in-memory fakes and need NONE of these.
# ============================================================================

# asyncpg DSN — plain postgresql:// (NOT a SQLAlchemy +driver URL)
DP_DATABASE_URL=postgresql://dishport:dishport@localhost:5432/dishport

# Providers — required to actually run the gate (the combined LLM call + embed).
DP_OPENAI_API_KEY=
DP_ANTHROPIC_API_KEY=

# Tunables
DP_DEDUP_TAU=0.90
DP_EMBEDDING_MODEL=text-embedding-3-small
DP_FLAVOR_MODEL=claude-sonnet-4-6

DP_LOG_LEVEL=INFO
